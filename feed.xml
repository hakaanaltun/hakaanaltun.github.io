---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <link>{{ site.url }}</link>
    <description>Essays and short fiction on perception, memory, and the things we carry without knowing&#8212;by Hakan Altun.</description>
    <language>en</language>
    <atom:link href="{{ site.url }}/feed.xml" rel="self" type="application/rss+xml"/>
    {% for post in site.posts %}
    {% assign c = post.content %}
    {% assign c = c | replace: '—', '&#8212;' %}
    {% assign c = c | replace: '–', '&#8211;' %}
    {% assign c = c | replace: ''', '&#8217;' %}
    {% assign c = c | replace: '…', '&#8230;' %}
    {% assign c = c | replace: '₺', '&#8378;' %}
    {% assign c = c | replace: 'Ş', '&#350;' %}
    {% assign c = c | replace: 'ş', '&#351;' %}
    {% assign c = c | replace: 'ı', '&#305;' %}
    {% assign c = c | replace: 'İ', '&#304;' %}
    {% assign c = c | replace: 'ü', '&#252;' %}
    {% assign c = c | replace: 'Ü', '&#220;' %}
    {% assign c = c | replace: 'ö', '&#246;' %}
    {% assign c = c | replace: 'ç', '&#231;' %}
    {% assign c = c | replace: 'Ç', '&#199;' %}
    {% assign c = c | replace: 'ğ', '&#287;' %}
    {% assign c = c | replace: 'é', '&#233;' %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ site.url }}{{ post.url }}</link>
      <guid isPermaLink="true">{{ site.url }}{{ post.url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      {% if post.image %}{% if post.image contains '.jpg' or post.image contains '.jpeg' %}<enclosure url="{{ site.url }}{{ post.image }}" type="image/jpeg" length="0"/>{% else %}<enclosure url="{{ site.url }}{{ post.image }}" type="image/png" length="0"/>{% endif %}{% endif %}
      <description><![CDATA[{% if post.image %}<p><img src="{{ site.url }}{{ post.image }}" alt="{{ post.title | xml_escape }}" style="max-width:100%;height:auto;margin-bottom:16px"></p>{% endif %}{{ c }}]]></description>
    </item>
    {% endfor %}
  </channel>
</rss>
