---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}</link>
    <atom:link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/rss+xml" />
    <language>en</language>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {% assign goodreads_featured = "the-anxiety,the-cove,handled,collateral" | split: "," %}
    {% for slug in goodreads_featured %}
      {% assign post = site.posts | where: "slug", slug | first %}
      {% if post %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <description>{{ post.description | default: post.subtitle | default: site.description | xml_escape }}</description>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      {% assign post_image = post.image | default: post.thumb %}
      {% if post_image %}<media:content url="{{ post_image | absolute_url }}" medium="image" />{% endif %}
      <content:encoded><![CDATA[{{ post.content }}]]></content:encoded>
    </item>
      {% endif %}
    {% endfor %}
    {% assign excluded_slugs = goodreads_featured %}
    {% for post in site.posts %}
      {% unless excluded_slugs contains post.slug %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <description>{{ post.description | default: post.subtitle | default: site.description | xml_escape }}</description>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      {% assign post_image = post.image | default: post.thumb %}
      {% if post_image %}<media:content url="{{ post_image | absolute_url }}" medium="image" />{% endif %}
      <content:encoded><![CDATA[{{ post.content }}]]></content:encoded>
    </item>
      {% endunless %}
    {% endfor %}
  </channel>
</rss>
