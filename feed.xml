---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}</link>
    <atom:link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/rss+xml" />
    <language>en</language>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>

    {%- comment -%}
      Pinned posts keep fixed Goodreads dates so their order never changes.
      Any post newer than the newest pinned date floats above the pinned block
      automatically; older posts fall below it.
      NOTE: For Goodreads, write Turkish/accented letters as HTML entities in the
      post source (e.g. &#304;stanbul, rak&#305;) — Goodreads mangles raw UTF-8.
    {%- endcomment -%}
    {% assign pinned = "collateral,handled,the-cove,the-anxiety" | split: "," %}
    {% assign pin_top_ts = "2026-05-26 12:00:00" | date: "%s" | plus: 0 %}

    {%- comment -%} 1) New posts, newer than the pinned block {%- endcomment -%}
    {% for post in site.posts %}
      {% unless pinned contains post.slug %}
        {% assign post_ts = post.date | date: "%s" | plus: 0 %}
        {% if post_ts > pin_top_ts %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <description>{{ post.description | default: post.subtitle | default: site.description | xml_escape }}</description>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      {% assign feed_image = post.image | default: post.thumb %}{% if feed_image %}<media:content url="{{ feed_image | absolute_url }}" medium="image" />{% endif %}
      <content:encoded><![CDATA[{% if feed_image %}<p><img src="{{ feed_image | absolute_url }}" alt="{{ post.cover_alt | default: post.title }}" /></p>{% endif %}{{ post.content }}]]></content:encoded>
    </item>
        {% endif %}
      {% endunless %}
    {% endfor %}

    {%- comment -%} 2) The four pinned posts — fixed order and dates {%- endcomment -%}
    {% for slug in pinned %}
      {% assign post = site.posts | where: "slug", slug | first %}
      {% if post %}
        {% assign rss_pubdate = "" %}
        {% if slug == "collateral" %}{% assign rss_pubdate = "Tue, 26 May 2026 12:00:00 +0000" %}{% endif %}
        {% if slug == "handled" %}{% assign rss_pubdate = "Mon, 25 May 2026 12:00:00 +0000" %}{% endif %}
        {% if slug == "the-cove" %}{% assign rss_pubdate = "Sun, 24 May 2026 12:00:00 +0000" %}{% endif %}
        {% if slug == "the-anxiety" %}{% assign rss_pubdate = "Sat, 23 May 2026 12:00:00 +0000" %}{% endif %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <description>{{ post.description | default: post.subtitle | default: site.description | xml_escape }}</description>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      <pubDate>{{ rss_pubdate }}</pubDate>
      {% assign feed_image = post.image | default: post.thumb %}{% if feed_image %}<media:content url="{{ feed_image | absolute_url }}" medium="image" />{% endif %}
      <content:encoded><![CDATA[{% if feed_image %}<p><img src="{{ feed_image | absolute_url }}" alt="{{ post.cover_alt | default: post.title }}" /></p>{% endif %}{{ post.content }}]]></content:encoded>
    </item>
      {% endif %}
    {% endfor %}

    {%- comment -%} 3) Everything else — older than the pinned block {%- endcomment -%}
    {% for post in site.posts %}
      {% unless pinned contains post.slug %}
        {% assign post_ts = post.date | date: "%s" | plus: 0 %}
        {% if post_ts <= pin_top_ts %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <description>{{ post.description | default: post.subtitle | default: site.description | xml_escape }}</description>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      {% assign feed_image = post.image | default: post.thumb %}{% if feed_image %}<media:content url="{{ feed_image | absolute_url }}" medium="image" />{% endif %}
      <content:encoded><![CDATA[{% if feed_image %}<p><img src="{{ feed_image | absolute_url }}" alt="{{ post.cover_alt | default: post.title }}" /></p>{% endif %}{{ post.content }}]]></content:encoded>
    </item>
        {% endif %}
      {% endunless %}
    {% endfor %}

  </channel>
</rss>
